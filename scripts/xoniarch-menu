#!/bin/bash
while true; do
    clear
    echo "========================================"
    echo "       XONIARCH - MENU PRINCIPAL"
    echo "========================================"
    echo "1) Nueva terminal"
    echo "2) Configurar red (nmtui)"
    echo "3) Reproducir YouTube"
    echo "4) Instalar herramienta XONI"
    echo "5) Actualizar sistema"
    echo "6) Detectar hardware"
    echo "7) Ayuda"
    echo "8) Salir"
    read -p "Opcion: " opt
    case $opt in
        1) urxvt & ;;
        2) sudo nmtui ;;
        3) read -p "URL: " url; mpv "$url" ;;
        4) xoniarch-install ;;
        5) sudo xoniarch-update ;;
        6) sudo xoniarch-detect-hardware ;;
        7) xoniarch-help ;;
        8) exit 0 ;;
    esac
done
