#!/bin/bash
echo "========================================"
echo "   XONIARCH - Deteccion de Hardware"
echo "========================================"
GPU=$(lspci | grep -E "VGA|3D" | grep -oE "Intel|NVIDIA|AMD" | head -1)
echo "GPU detectada: $GPU"
case $GPU in
    Intel)
        echo "Instalando controladores Intel..."
        pacman -S --noconfirm xf86-video-intel
        ;;
    NVIDIA)
        echo "Instalando controladores NVIDIA..."
        pacman -S --noconfirm nvidia nvidia-utils
        ;;
    AMD)
        echo "Instalando controladores AMD..."
        pacman -S --noconfirm xf86-video-amdgpu
        ;;
    *)
        echo "Usando controlador generico VESA..."
        pacman -S --noconfirm xf86-video-vesa
        ;;
esac
echo "Controladores instalados correctamente"
