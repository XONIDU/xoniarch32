#!/bin/bash
while true; do
    clear
    echo "========================================"
    echo "       XONIARCH - MENU PRINCIPAL"
    echo "========================================"
    echo "1) Configurar red (nmtui)"
    echo "2) Instalar XONIARCH"
    echo "3) Actualizar sistema"
    echo "4) Ayuda"
    echo "5) Salir"
    echo "========================================"
    read -p "Opcion: " opt
    case $opt in
        1) 
            echo "Abriendo nmtui..."
            nmtui
            ;;
        2) 
            echo "Instalando XONIARCH..."
            /usr/local/bin/xoniarch-install
            ;;
        3) 
            echo "Actualizando sistema..."
            /usr/local/bin/xoniarch-update
            ;;
        4) 
            echo "========================================"
            echo "COMANDOS DISPONIBLES:"
            echo "  xoniarch-menu      - Este menu"
            echo "  xoniarch-install   - Instalar XONIARCH"
            echo "  xoniarch-update    - Actualizar sistema"
            echo "  nmtui              - Configurar red"
            echo "========================================"
            read -p "Presiona Enter para continuar..."
            ;;
        5) 
            echo "Saliendo..."
            exit 0
            ;;
        *)
            echo "Opcion invalida"
            sleep 1
            ;;
    esac
done
